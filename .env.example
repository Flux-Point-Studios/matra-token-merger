# Network selection: mainnet | preprod | preview
NETWORK=mainnet

# Blockfrost API keys (per network)
BLOCKFROST_PROJECT_ID="mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
BLOCKFROST_PROJECT_ID_PREPROD="preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# TapTools API key (mainnet only)
TAP_TOOLS_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Token identifiers (mainnet legacy assets)
AGENT_POLICY=97bbb7db0baef89caefce61b8107ac74c7a7340166b39d906f174bec
AGENT_NAME_HEX=54616c6f73

SHARDS_POLICY=ea153b5d4864af15a1079a94a0e2486d6376fa28aafad272d15b243a
SHARDS_NAME_HEX=0014df10536861726473

# ──────────────────────────────────────────────────────────────────────────
# Dual-admin payment key hashes
# ──────────────────────────────────────────────────────────────────────────
# Both the surrender pool validator and the cMATRA mint policy are
# parameterized by TWO admin keys, held on two separate physical machines
# (Server A + Server B). Every surrender, mint, and admin-sweep transaction
# must be signed by both keys.
#
# Each PKH is 28 bytes hex (56 chars). Lower-case hex, no 0x prefix.
ADMIN_PKH_1=""
ADMIN_PKH_2=""

# ──────────────────────────────────────────────────────────────────────────
# Co-signer service (Server B)
# ──────────────────────────────────────────────────────────────────────────
# Server A (running surrender_api.py) talks to Server B over LAN-only HTTPS.
# Server B holds admin_2.skey and signs only after pattern-checking the tx.
COSIGNER_URL="http://<server-b-lan-ip>:8421"
COSIGNER_API_SECRET="CHANGE_ME_generate_with_secrets_token_urlsafe"

# Claim deadline — POSIX milliseconds (e.g. 1750000000000 ≈ mid-2025).
# After this time the admins can co-sign a sweep of any unclaimed cMATRA
# from the surrender pool.
CLAIM_DEADLINE_POSIX_MS=0

# ──────────────────────────────────────────────────────────────────────────
# Quarantine address
# ──────────────────────────────────────────────────────────────────────────
# Surrendered legacy assets (AGENT / SHARDS / FLUX_PASS / SE_BRAWLERS /
# BRAWL_PASS_ETD / T1_ADAM_PASS / T2_ADAM_PASS) land here and are
# permanently unspendable. The destination is an always-fails Plutus V3
# validator at onchain/quarantine_validator/ — there is no key and no
# admin path. Anyone can rebuild the validator from source (Aiken v1.1.21)
# and re-derive the address to verify; expected script hash is
# 288fea77a0f674c6080aadd8ed3ca42cd5a920bf1f00c0d3e63306e4.
QUARANTINE_ADDRESS_MAINNET="addr1wy5gl6nh5rm8f3sgp2ka3mfu5skdt2fqhu0spsxnucesdeqatlhxl"
QUARANTINE_ADDRESS_PREPROD="addr_test1wq5gl6nh5rm8f3sgp2ka3mfu5skdt2fqhu0spsxnucesdeqxrttf6"

# Koios API key (optional — free tier works for cross-checks)
KOIOS_API_KEY=""
