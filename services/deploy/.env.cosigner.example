# ============================================================================
# Co-Signer Environment Variables (Server B — GMKTec)
# ============================================================================
# Copy this to .env.cosigner and fill in the values.
# NEVER commit .env.cosigner to git.
# ============================================================================

# Path to admin key 2 (.skey) — INSIDE the container (mapped via volume)
COSIGNER_SKEY_PATH=/app/keys/admin_2.skey

# Shared secret with Server A — must match COSIGNER_API_SECRET on Server A.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
COSIGNER_API_SECRET=CHANGE_ME_generate_with_secrets_token_urlsafe

# Port (default 8421)
COSIGNER_API_PORT=8421
