# Cardano SPO Delegation Rewards - Configuration
# Copy to .env and fill in values

# TALOS pool ID (bech32)
POOL_ID=pool1qqhk0m3ew3jn4njkftxuxxpt5qfnf0pqvnzn2y52nc7yq8rlpq6

# Blockfrost API key (mainnet project)
BLOCKFROST_API_KEY=

# cMATRA per 1000 ADA per epoch (base units, 6 decimals)
# Example: 100 = 0.000100 cMATRA per 1000 ADA
REWARD_RATE=100

# cMATRA policy ID (hex)
POLICY_ID=

# Paths to policy and signing keys
# Uses the repo's shared mint policy by default
POLICY_SCRIPT_PATH=../onchain/flux_mint_policy/mint_policy.json
POLICY_SKEY_PATH=../onchain/flux_mint_policy/policy.skey
PAYMENT_SKEY_PATH=./keys/payment.skey

# Change address for TX building
CHANGE_ADDRESS=

# cardano-cli binary path
CARDANO_CLI_PATH=cardano-cli

# Network: mainnet or testnet
NETWORK=mainnet

# SQLite DB path
DB_PATH=./ledger.sqlite

# Max outputs per TX (Cardano limit is ~50-80 depending on token size)
MAX_OUTPUTS_PER_TX=50

# Min lovelace per UTxO output
MIN_UTXO_LOVELACE=1500000
