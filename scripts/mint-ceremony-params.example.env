# --- Network ---
NETWORK_MAGIC="--mainnet"          # mainnet sentinel for cardano-cli
NETWORK_KOIOS="https://api.koios.rest/api/v1"

# --- Admin keys (per-host paths; admin_1 on Gemtek, admin_2 on Node-3) ---
# OPERATOR: set this to the path on your host
ADMIN_1_SKEY="/home/deci/cmatra-merger-keys/admin_1.skey"
# OPERATOR: set this to the path on your host
ADMIN_1_VKEY="/home/deci/cmatra-merger-keys/admin_1.vkey"
ADMIN_1_ADDR="__ADMIN_1_ADDR__  # OPERATOR: bech32 admin_1 enterprise address"
ADMIN_PKH_1="__ADMIN_PKH_1__  # OPERATOR: 28-byte hex"

# OPERATOR: set this to the path on your host
ADMIN_2_VKEY="/home/deci/cmatra-merger-keys/admin_2.vkey"   # vkey only on Gemtek
# OPERATOR: set this to the path on your host
ADMIN_2_SKEY_REMOTE="/home/deci/cmatra-merger-keys/admin_2.skey"   # path on Node-3
# OPERATOR: set this to the path on your host
ADMIN_2_HOST="deci@192.168.0.133"
ADMIN_PKH_2="__ADMIN_PKH_2__  # OPERATOR: 28-byte hex"

# --- Locked mint policy params ---
SEED_UTXO_TXID="__SEED_UTXO_TXID__  # OPERATOR: replace with fresh seed UTxO txhash at admin_1 (5 ADA)"
SEED_UTXO_IDX="0"                       # the 5 ADA UTxO at admin_1
SEED_UTXO="${SEED_UTXO_TXID}#${SEED_UTXO_IDX}"

RESERVE_UTXO_TXID="__RESERVE_UTXO_TXID__  # OPERATOR: replace with reserve UTxO txhash at admin_1 (35 ADA)"
RESERVE_UTXO_IDX="0"                    # the 35 ADA UTxO at admin_1
RESERVE_UTXO="${RESERVE_UTXO_TXID}#${RESERVE_UTXO_IDX}"

# --- Locked validator params (claim_validator) ---
CLAIM_DEADLINE_POSIX_MS=__DEADLINE_POSIX_MS__  # OPERATOR: POSIX ms; cMATRA v1 used 1795910400000 (2026-11-29)   # 2026-11-29 00:00:00 UTC

# --- cMATRA asset spec ---
CMATRA_POLICY_ID="__POLICY_ID__  # OPERATOR: blake2b224(0x03 || applied_compiled_cbor)"
CMATRA_ASSET_NAME_HEX="634d41545241"    # "cMATRA"
CMATRA_UNIT="${CMATRA_POLICY_ID}.${CMATRA_ASSET_NAME_HEX}"
CMATRA_TOTAL_SUPPLY_BASE="1000000000000000"      # 1 B × 10^6
CMATRA_POOL_AMOUNT_BASE="722500000000000"        # 722.5 M × 10^6 → surrender_pool
CMATRA_RESERVE_AMOUNT_BASE="277500000000000"     # 277.5 M × 10^6 → admin_1

# --- Surrender pool (claim_validator surrender_pool, applied with deadline) ---
SURRENDER_POOL_SCRIPT_HASH="__SURRENDER_POOL_SCRIPT_HASH__  # OPERATOR: from applied claim_validator"
SURRENDER_POOL_ADDR="__SURRENDER_POOL_ADDR__  # OPERATOR: bech32 of surrender_pool script (mainnet)"

# --- Quarantine (referenced for runbook completeness; not used in mint tx) ---
QUARANTINE_SCRIPT_HASH="__QUARANTINE_SCRIPT_HASH__"
QUARANTINE_ADDR="__QUARANTINE_ADDR__"

# --- Repo blueprints (source) ---
# OPERATOR: set this to the path on your host
REPO_ROOT="/home/deci/work/matra-merger-prep"
# OPERATOR: set this to the path on your host
MINT_POLICY_SRC="${REPO_ROOT}/onchain/flux_mint_policy/plutus.json"

# --- Output artifacts (this ceremony's working directory) ---
# OPERATOR: set this to the path on your host
OUT_DIR="/home/deci/cmatra-mint-ceremony"
# OPERATOR: set this to the path on your host
APPLIED_BLUEPRINT="${OUT_DIR}/mint-policy.applied-final.json"
# OPERATOR: set this to the path on your host
APPLIED_SCRIPT_FILE="${OUT_DIR}/mint-policy.applied.plutus"
# OPERATOR: set this to the path on your host
MINT_REDEEMER_FILE="${OUT_DIR}/mint-redeemer.json"
# OPERATOR: set this to the path on your host
PROTOCOL_PARAMS_FILE="${OUT_DIR}/protocol-params.json"
# OPERATOR: set this to the path on your host
TX_RAW="${OUT_DIR}/mint-tx.raw"
# OPERATOR: set this to the path on your host
TX_ADMIN1_SIGNED="${OUT_DIR}/mint-tx.admin_1-signed.json"
# OPERATOR: set this to the path on your host
TX_ADMIN2_WITNESS="${OUT_DIR}/mint-tx.admin_2.witness"
# OPERATOR: set this to the path on your host
TX_FINAL="${OUT_DIR}/mint-tx.signed.json"

# --- Tx outputs (min-UTxO + asset) ---
POOL_OUTPUT_ADA=2000000                 # 2 ADA min-UTxO for asset-bearing output
RESERVE_OUTPUT_ADA=2000000              # 2 ADA min-UTxO for asset-bearing output

# --- Ex-units (CONSERVATIVE estimates; refine after preflight) ---
# Reference: flux_mint_policy is a small validator with ~10 boolean checks
# over tx.mint, tx.inputs, tx.extra_signatories. Conservative ceiling:
EX_UNITS_MEM=2000000                    # 2 M memory units
EX_UNITS_CPU=500000000                  # 500 M cpu units

# --- Validity window ---
# We bind a 4-hour validity window so the tx isn't accepted after that
# time (limits an attacker who steals the partially-signed tx from
# resubmitting it). The lower bound is slot_now; upper bound is +14400 slots.
TX_VALIDITY_HOURS=4
