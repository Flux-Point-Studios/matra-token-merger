# Mainnet values pinned 2026-05-18 from:
#   - mint ceremony at commit 79de97e (PR #3)
#   - claim_validator blueprint at commit 03bdd4d (PR #6)
#   - mint tx 9a68849fd788... (block 13435752, epoch 631)
#
# Execution window opens 2026-11-29 00:00:00 UTC. This file is READ-ONLY
# until then.
# ====================================================================

# --- Network ---
NETWORK_MAGIC="--mainnet"
NETWORK_KOIOS="https://api.koios.rest/api/v1"
NETWORK_NAME="mainnet"

# --- Admin keys (per-host paths; admin_1 on Gemtek, admin_2 on Node-3) ---
ADMIN_1_SKEY="/home/deci/cmatra-merger-keys/admin_1.skey"
ADMIN_1_VKEY="/home/deci/cmatra-merger-keys/admin_1.vkey"
ADMIN_1_ADDR="addr1v8c7a6pg46qq5kadduu3xcp7ypf3zckd73x9url6fxm2jdsg639d3"
ADMIN_PKH_1="f1eee828ae800a5bad6f3913603e20531162cdf44c5e0ffa49b6a936"

ADMIN_2_VKEY="/home/deci/cmatra-merger-keys/admin_2.vkey"
ADMIN_2_SKEY_REMOTE="/home/deci/cmatra-merger-keys/admin_2.skey"
ADMIN_2_HOST="deci@192.168.0.133"
ADMIN_PKH_2="77fdb621ad5f926257ce1a2f845fc946ae3d5a683ac89128bad3410d"

# --- Surrender-pool validator (claim_validator.surrender_pool, applied with admins+deadline) ---
SURRENDER_POOL_SCRIPT_HASH="e1a181b2f8b74be55e6160a7a82764b9b174e04c37c4ed49d349a3dd"
SURRENDER_POOL_ADDR="addr1w8s6rqdjlzm5he27v9s202p8vjumza8qfsmufm2f6dy68hg9mn27a"

# --- Deadline (POSIX ms — matches deadline parameter baked into surrender_pool) ---
CLAIM_DEADLINE_POSIX_MS=1795910400000              # 2026-11-29 00:00:00 UTC
CLAIM_DEADLINE_SLOT_MAINNET=203912109              # = 4492800 + (1795910400 - 1596491091)
# Buffer on top of the deadline slot so is_entirely_after is unambiguous.
# 60s is plenty (validator only checks tx.validity_range.lower > deadline).
DEADLINE_BUFFER_SLOTS=60

# --- cMATRA asset spec ---
CMATRA_POLICY_ID="98c61f406f7c8df11ccff49ca1631d8bca9663894537c6c5ee5ed418"
CMATRA_ASSET_NAME_HEX="634d41545241"               # "cMATRA"
CMATRA_UNIT="${CMATRA_POLICY_ID}.${CMATRA_ASSET_NAME_HEX}"

# --- Repo / blueprint source ---
REPO_ROOT="/home/deci/work/matra-merger-prep"
CLAIM_VALIDATOR_BLUEPRINT="${REPO_ROOT}/onchain/claim_validator/plutus.json"

# --- Pinned pool UTxO snapshot (the original, pre-claim deposit) ---
# Used only as the dry-run target. Run-time selects the live UTxO from Koios.
SNAPSHOT_POOL_TX_HASH="9a68849fd788fb3622bc5823d892b61c2e94ff57416b190300ee49f3dc7cb6a2"
SNAPSHOT_POOL_TX_INDEX="0"

# --- Default sweep destination (admin_1 reserve address) ---
# Override at runtime with --to <bech32 address>.
DEFAULT_SWEEP_DEST_ADDR="addr1v8c7a6pg46qq5kadduu3xcp7ypf3zckd73x9url6fxm2jdsg639d3"

# --- Output artifacts ---
OUT_DIR="${OUT_DIR:-/home/deci/cmatra-sweep-ceremony}"
APPLIED_SPEND_BLUEPRINT="${OUT_DIR}/spend-pool.applied.json"
APPLIED_SPEND_SCRIPT_FILE="${OUT_DIR}/spend-pool.applied.plutus"
SWEEP_DATUM_FILE="${OUT_DIR}/sweep-datum.json"
SWEEP_REDEEMER_FILE="${OUT_DIR}/sweep-redeemer.json"
PROTOCOL_PARAMS_FILE="${OUT_DIR}/protocol-params.json"
POOL_UTXO_FILE="${OUT_DIR}/pool-utxo.json"
TX_RAW="${OUT_DIR}/sweep-tx.raw"
TX_ADMIN1_SIGNED="${OUT_DIR}/sweep-tx.admin_1-signed.json"
TX_ADMIN2_WITNESS="${OUT_DIR}/sweep-tx.admin_2.witness"
TX_FINAL="${OUT_DIR}/sweep-tx.signed.json"

# --- Tx fee + min-utxo + collateral knobs ---
# Min UTxO for the asset-bearing destination output (2 ADA is safe baseline; the
# Python helper will widen this if needed for large asset bundles).
DEST_OUTPUT_ADA=2000000

# Min collateral for Plutus script spend — must be at least
# collateral_percentage * fee. Default 5 ADA covers typical fees of ~1-2 ADA.
COLLATERAL_ADA=5000000

# Conservative spend-script ex-units. claim_validator surrender_pool is small
# (~10 list/interval checks). Empirically: ~1.5M mem, ~400M cpu on Plutus V3.
EX_UNITS_MEM=2000000
EX_UNITS_CPU=600000000

# Validity window: lower=deadline+buffer (above), upper=lower+TX_VALIDITY_HOURS*3600 slots.
TX_VALIDITY_HOURS=4
